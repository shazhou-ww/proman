{
  "name": "@shazhou/proman-workspace",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "description": "Project manager CLI for TypeScript monorepos",
  "keywords": [
    "typescript",
    "monorepo",
    "build",
    "cli",
    "pnpm",
    "biome",
    "vitest"
  ],
  "scripts": {
    "test": "pnpm -r --workspace-concurrency=1 test",
    "check": "biome check .",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@ocas/cli-kit": "^0.2.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "wrangler": {
      "optional": true
    }
  }
}
